# Copy to .env and fill in as needed. The default Bedrock VLM provider uses the
# standard AWS credential chain (profile / env / instance role) — no static keys.

# AWS_PROFILE=default
# AWS_REGION=us-east-1

# Only for offline dev with the direct Anthropic API (provider: anthropic):
# ANTHROPIC_API_KEY=

# Only for the NVIDIA endpoint (provider: nvidia):
# NVIDIA_API_KEY=
